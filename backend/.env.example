

# ── Anti-snipe configuration ──────────────────────────────────────────────────
# Bids placed within this window (ms) before auction end trigger an extension.
ANTISNIPE_WINDOW_MS=30000

# How long (ms) to extend the auction when anti-snipe fires.
ANTISNIPE_EXTEND_MS=30000

# ── Security ──────────────────────────────────────────────────────────────────
# How often (ms) to revalidate JWT tokens on active WebSocket connections.
SOCKET_REVALIDATE_MS=300000

# Maximum number of live auctions a single buyer can simultaneously lead.
MAX_CONCURRENT_BIDS=5

# ── Bid engine ────────────────────────────────────────────────────────────────
# Minimum increment (₹/kg) above current bid for a new bid to be accepted.
MIN_BID_INCREMENT=1
